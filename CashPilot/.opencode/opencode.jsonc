        "google/gemma-4-26b-a4b-qat": {
          "name": "Gemma 4 26B A4B QAT (local)",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "google/gemma-4-31b-qat": {
          "name": "Gemma 4 31B QAT (local)",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
