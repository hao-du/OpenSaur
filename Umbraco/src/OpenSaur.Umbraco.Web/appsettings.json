{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=<storage-account>;AccountKey=<storage-account-key>;EndpointSuffix=core.windows.net",
          "ContainerName": "blob-media"
        }
      }
    },
    "CMS": {
      "Global": {
        "Id": "a8713fd1-43bd-4ba5-9645-89ba1a6c016a"
      },
      "BasicAuth": {
        "RedirectToLoginPage": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Imaging": {
        "HMACSecretKey": "92blx1AXOXM0mxyiIeLBBTo4wfb50vH049cFVAr6duv1jeT9mnQlAHbLi9lRiHS\u002B8Q\u002BmUeENNklgf62v1T8hRg=="
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Host=<db-host>;Port=5432;SSL Mode=VerifyCA;Database=<db-name>;Username=<db-user>;Password=<db-password>",
    "umbracoDbDSN_ProviderName": "Npgsql2"
  },
  "Oidc": {
    "Authority": "https://coregate.duchihao.com",
    "ClientId": "umbraco-web",
    "ClientSecret": "<oidc-client-secret>",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "DefaultCulture": "en-US",
    "AllowInsecureDiscoveryEndpoints": true
  }
}
