{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ConnectionString": "<connection string>",
          "ContainerName": "blob-media"
        }
      }
    },
    "CMS": {
      "Global": {
        "Id": "a8713fd1-43bd-4ba5-9645-89ba1a6c016a"
      },
      "BasicAuth": {
        "RedirectToLoginPage": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Imaging": {
        "HMACSecretKey": ""
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Npgsql2"
  },
  "Oidc": {
    "Authority": "https://coregate.duchihao.com",
    "ClientId": "umbraco-web",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "DefaultCulture": "en-US",
    "AllowInsecureDiscoveryEndpoints": true
  }
}
