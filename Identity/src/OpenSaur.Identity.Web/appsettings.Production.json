{
  "ConnectionStrings": {
    "IdentityDb": "Host=<prod-db-host>;Port=5432;Database=<prod-db-name>;Username=<prod-db-user>;Password=<prod-db-password>"
  },
  "Oidc": {
    "Issuer": "https://identity.example.com",
    "SigningCertificatePath": "<prod-oidc-signing-certificate-path>",
    "SigningCertificatePassword": "<prod-oidc-signing-certificate-password>",
    "EncryptionCertificatePath": "<prod-oidc-encryption-certificate-path>",
    "EncryptionCertificatePassword": "<prod-oidc-encryption-certificate-password>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
