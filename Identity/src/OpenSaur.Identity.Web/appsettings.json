{
  "ConnectionStrings": {
    "IdentityDb": "Host=<db-host>;Port=5432;Database=<db-name>;Username=<db-user>;Password=<db-password>"
  },
  "Oidc": {
    "Issuer": "https://identity.example.com",
    "SigningCertificatePath": "<oidc-signing-certificate-path>",
    "SigningCertificatePassword": "<oidc-signing-certificate-password>",
    "EncryptionCertificatePath": "<oidc-encryption-certificate-path>",
    "EncryptionCertificatePassword": "<oidc-encryption-certificate-password>"
  },
  "EndpointResilience": {
    "RateLimiting": {
      "Default": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Auth": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Token": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Idempotency": {
      "HeaderName": "Idempotency-Key",
      "ReplayRetentionMinutes": 5
    },
    "CircuitBreaker": {
      "Default": {
        "FailureThreshold": 5,
        "BreakDurationSeconds": 30
      },
      "Auth": {
        "FailureThreshold": 3,
        "BreakDurationSeconds": 30
      },
      "Token": {
        "FailureThreshold": 3,
        "BreakDurationSeconds": 30
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
