{
  "ConnectionStrings": {
    "IdentityDb": "Host=<db-host>;Port=5432;Database=<db-name>;Username=<db-user>;Password=<db-password>",
    "Redis": "<redis-configuration>"
  },
  "Oidc": {
    "Issuer": "http://gateway.example.com/identity",
    "CurrentAppBaseUri": "http://gateway.example.com/identity",
    "BootstrapClient": {
      "AppPathBase": "/identity",
      "CallbackPath": "/auth/callback",
      "ClientId": "first-party-web",
      "ClientSecret": "<first-party-web-client-secret>",
      "DisplayName": "OpenSaur Identity First-Party Admin Shell",
      "PostLogoutPath": "/auth-required",
      "Scope": "openid profile email roles offline_access api",
      "Origins": [
        "http://gateway.example.com/",
        "http://localhost:5220/"
      ]
    },
    "CurrentClient": {
      "ClientId": "first-party-web",
      "ClientSecret": "<first-party-web-client-secret>"
    },
    "SigningCertificatePath": "<oidc-signing-certificate-path>",
    "SigningCertificatePassword": "<oidc-signing-certificate-password>",
    "EncryptionCertificatePath": "<oidc-encryption-certificate-path>",
    "EncryptionCertificatePassword": "<oidc-encryption-certificate-password>"
  },
  "GoogleRecaptchaV3": {
    "Enabled": false,
    "SiteKey": "",
    "SecretKey": "",
    "MinimumScore": 0.5,
    "LoginAction": "login"
  },
  "EndpointResilience": {
    "RateLimiting": {
      "Default": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Auth": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Token": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Idempotency": {
      "HeaderName": "Idempotency-Key",
      "ReplayRetentionMinutes": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
