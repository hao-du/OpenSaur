{
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "cms-home": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "cms-root": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms" }
        ]
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identityApp": {
            "Address": "https://ca-identity.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "https://ca-umbraco.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
