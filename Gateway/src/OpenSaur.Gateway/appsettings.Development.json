{
  "ReverseProxy": {
    "Routes": {
      "cms-home": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "cms-root": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms" }
        ]
      },
      "umbraco-backoffice": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/umbraco/{**catch-all}"
        }
      },
      "umbraco-signin": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signin-oidc"
        }
      },
      "umbraco-signout": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signout-callback-oidc"
        }
      }
    },
    "Clusters": {
      "zentry": {
        "Destinations": {
          "zentryApp": {
            "Address": "https://ca-zentry.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      },
      "coregate": {
        "Destinations": {
          "coregateApp": {
            "Address": "https://ca-coregate.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "https://ca-umbraco.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GatewayDirectForwarding": {
    "Hosts": {
      "coregate.duchihao.com": "coregate",
      "zentry.duchihao.com": "zentry"
    }
  }
}
