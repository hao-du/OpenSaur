{
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "zentry": {
        "ClusterId": "zentry",
        "Match": {
          "Path": "/{**catch-all}",
          "Headers": [
            {
              "Name": "Host",
              "Values": [ "zentry.duchihao.com" ],
              "Mode": "ExactHeader"
            }
          ]
        }
      },
      "coregate": {
        "ClusterId": "coregate",
        "Match": {
          "Path": "/{**catch-all}",
          "Headers": [
            {
              "Name": "Host",
              "Values": [ "coregate.duchihao.com" ],
              "Mode": "ExactHeader"
            }
          ]
        }
      },
      "cms-home": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "cms-root": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms" }
        ]
      },
      "umbraco-backoffice": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/umbraco/{**catch-all}"
        }
      },
      "umbraco-signin": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signin-oidc"
        }
      },
      "umbraco-signout": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signout-callback-oidc"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identityApp": {
            "Address": "https://ca-identity.bluesea-ebd8152c.canadacentral.azurecontainerapps.io"
          }
        }
      },
      "zentry": {
        "Destinations": {
          "zentryApp": {
            "Address": "https://localhost:5011/"
          }
        }
      },
      "coregate": {
        "Destinations": {
          "coregateApp": {
            "Address": "https://localhost:5001/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "https://ca-umbraco.bluesea-ebd8152c.canadacentral.azurecontainerapps.io/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
