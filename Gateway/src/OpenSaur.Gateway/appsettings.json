{
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "zentry-home": {
        "ClusterId": "zentry",
        "Match": {
          "Path": "/zentry"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "zentry-root": {
        "ClusterId": "zentry",
        "Match": {
          "Path": "/zentry/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/zentry" }
        ]
      },
      "coregate-home": {
        "ClusterId": "coregate",
        "Match": {
          "Path": "/coregate"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "coregate-root": {
        "ClusterId": "coregate",
        "Match": {
          "Path": "/coregate/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/coregate" }
        ]
      },
      "zentry": {
        "ClusterId": "zentry",
        "Match": {
          "Hosts": [ "<zentry-host>" ],
          "Path": "/{**catch-all}"
        }
      },
      "coregate": {
        "ClusterId": "coregate",
        "Match": {
          "Hosts": [ "<coregate-host>" ],
          "Path": "/{**catch-all}"
        }
      },
      "cms-home": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms"
        },
        "Transforms": [
          { "PathSet": "/" }
        ]
      },
      "cms-root": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms" }
        ]
      },
      "umbraco-backoffice": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/umbraco/{**catch-all}"
        }
      },
      "umbraco-signin": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signin-oidc"
        }
      },
      "umbraco-signout": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signout-callback-oidc"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identityApp": {
            "Address": "http://<identity-base-url>/"
          }
        }
      },
      "zentry": {
        "Destinations": {
          "zentryApp": {
            "Address": "http://<zentry-base-url>/"
          }
        }
      },
      "coregate": {
        "Destinations": {
          "coregateApp": {
            "Address": "http://<coregate-base-url>/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "http://<umbraco-base-url>/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
