{
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "cms-backend": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/backend/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms/backend" },
          { "PathPrefix": "/umbraco" }
        ]
      },
      "cms-root": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cms" }
        ]
      },
      "cms-signin-oidc": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signin-oidc"
        },
        "Transforms": [
          { "PathSet": "/signin-oidc" }
        ]
      },
      "cms-signout-callback-oidc": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/cms/signout-callback-oidc"
        },
        "Transforms": [
          { "PathSet": "/signout-callback-oidc" }
        ]
      },
      "umbraco-static": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/umbraco/{**catch-all}"
        }
      },
      "umbraco-media": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/media/{**catch-all}"
        }
      },
      "umbraco-favicon": {
        "ClusterId": "umbraco",
        "Match": {
          "Path": "/favicon.ico"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identityApp": {
            "Address": "http://<identity-base-url>/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "http://<umbraco-base-url>/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
