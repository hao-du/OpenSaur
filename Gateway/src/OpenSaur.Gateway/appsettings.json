{
  "ReverseProxy": {
    "Routes": {
    },
    "Clusters": {
      "zentry": {
        "Destinations": {
          "zentryApp": {
            "Address": "http://<zentry-base-url>/"
          }
        }
      },
      "coregate": {
        "Destinations": {
          "coregateApp": {
            "Address": "http://<coregate-base-url>/"
          }
        }
      },
      "umbraco": {
        "Destinations": {
          "umbracoApp": {
            "Address": "http://<umbraco-base-url>/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GatewayDirectForwarding": {
    "Hosts": {
      "<coregate-host>": "coregate",
      "<zentry-host>": "zentry",
      "<umbraco-host>": "umbraco"
    }
  },
  "Gateway": {
    "RateLimiting": {
      "PermitLimit": 150,
      "QueueLimit": 0,
      "WindowSeconds": 10
    },
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "BreakDurationSeconds": 30
    }
  },
  "AllowedHosts": "*"
}
